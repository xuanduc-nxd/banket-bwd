# Supabase Configuration (Lấy từ Project Settings -> API trên Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase Service Role Key (Chỉ dùng cho script seed dữ liệu ở Backend, tuyệt đối không lộ ở client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# VietMap Map API Configuration (Đăng ký tại maps.vietmap.vn để lấy key)
VIETMAP_API_KEY=your-vietmap-api-key-here
